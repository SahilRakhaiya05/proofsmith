# ─── Public app (required on Vercel — no trailing slash) ───
APP_URL=https://your-app.vercel.app
PROOFSMITH_PRODUCTION_URL=https://your-app.vercel.app

# ─── GitHub OAuth (human identity) ───
# Callback MUST be: ${APP_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=

# ─── GitHub worker / webhook ───
GITHUB_WEBHOOK_SECRET=
PROOFSMITH_GITHUB_TOKEN=

# ─── TestSprite checker (live URL only) ───
# https://github.com/TestSprite/testsprite-cli
TESTSPRITE_API_KEY=
TESTSPRITE_API_URL=https://api.testsprite.com
TESTSPRITE_PROJECT_ID=
TESTSPRITE_CRITICAL_TEST_IDS=

# ─── E2B maker sandboxes ───
E2B_API_KEY=
E2B_API_URL=https://api.e2b.dev
E2B_TEMPLATE_ID=base

# ─── Google Gemini (maker / triage / reviewer agents) ───
# Prefer GEMINI_API_KEY from Google AI Studio
GEMINI_API_KEY=
# Optional aliases also accepted:
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# MODEL_PROVIDER_API_KEY=
# Optional hard pin; if unset, API listModels picks best (prefers gemini-2.5-pro)
GEMINI_MODEL=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
