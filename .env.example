# Public app URL (required on Vercel / production — no trailing slash)
APP_URL=https://your-app.vercel.app
PROOFSMITH_PRODUCTION_URL=https://your-app.vercel.app

# GitHub OAuth App (identity for humans)
# Callback must be: ${APP_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=

# GitHub worker / webhook
GITHUB_WEBHOOK_SECRET=
PROOFSMITH_GITHUB_TOKEN=

# TestSprite cloud (official CLI facade)
# https://github.com/TestSprite/testsprite-cli
TESTSPRITE_API_KEY=
TESTSPRITE_API_URL=https://api.testsprite.com
TESTSPRITE_PROJECT_ID=
TESTSPRITE_CRITICAL_TEST_IDS=

# E2B isolated sandboxes for maker worktrees
E2B_API_KEY=
E2B_API_URL=https://api.e2b.dev
E2B_TEMPLATE_ID=base

# Optional model provider for maker/reviewer agents
MODEL_PROVIDER_API_KEY=
